# Vista Authen - Environment Configuration
# Copy this to .env and adjust values for your environment

# Database
DATABASE_URL=postgresql+asyncpg://vista:vista@localhost:5432/vista_authen
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-production-use-a-strong-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Activation token
ACTIVATION_TOKEN_TTL_HOURS=24

# QR verification
QR_TIMESTAMP_TOLERANCE_SEC=60

# CORS (comma-separated origins)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# Domain Configuration
DOMAIN_NAME=example.com